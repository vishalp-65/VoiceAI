# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your three API keys.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Required API keys -----------------------------------------------------
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# --- LLM provider ----------------------------------------------------------
# "openrouter" (OpenAI-compatible, default) or "anthropic" (Messages API).
LLM_PROVIDER=openrouter

# OpenRouter (used when LLM_PROVIDER=openrouter). Key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OpenRouter model slug — Claude Haiku 4.5 = lowest time-to-first-token.
# Swap to anthropic/claude-sonnet-4.6 for stronger reasoning at higher latency.
LLM_MODEL=anthropic/claude-haiku-4.5

# Anthropic direct (used only when LLM_PROVIDER=anthropic). When switching, also
# set LLM_MODEL to the Anthropic id, e.g. claude-haiku-4-5-20251001.
ANTHROPIC_API_KEY=
# Optional: Azure-hosted Anthropic or a custom proxy endpoint.
# ANTHROPIC_BASE_URL=

# Deepgram streaming STT model.
STT_MODEL=nova-3

# Cartesia Sonic TTS model + voice id (this is a stock Cartesia English voice).
TTS_MODEL=sonic-2
TTS_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# --- Turn-taking / latency knobs -------------------------------------------
# Seconds of silence before the agent gently checks "are you still there?".
IDLE_TIMEOUT_SECONDS=6.0

# Allow the caller to barge in (interrupt the agent mid-sentence).
ALLOW_INTERRUPTIONS=true

# --- WebRTC ICE (NAT traversal) --------------------------------------------
# Locally, the default STUN server is enough. On a PaaS like Render (which does
# not route inbound UDP to arbitrary ports) a TURN relay is REQUIRED or the
# browser/server media connection times out ("Timeout establishing the
# connection to the remote peer"). Get TURN credentials from a provider such as
# Cloudflare Calls, Twilio, or Metered, then set the three vars below.
STUN_URL=stun:stun.l.google.com:19302
# Comma-separated; include both turn: (UDP/TCP 3478) and turns: (TLS 5349).
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
# TURN_USERNAME=
# TURN_CREDENTIAL=

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=7860

# Path to the local SQLite store (created/seeded by scripts/seed_db.py).
DATABASE_PATH=data/voiceai.db

# Clinic timezone used when resolving "tomorrow", slot times, etc.
CLINIC_TIMEZONE=America/New_York
