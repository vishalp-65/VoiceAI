# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in your three API keys.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Required API keys -----------------------------------------------------
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
# Optional: set if using Azure-hosted Anthropic or a custom proxy endpoint.
# ANTHROPIC_BASE_URL=
CARTESIA_API_KEY=

# --- Model selection (sensible low-latency defaults) -----------------------
# Claude Haiku 4.5 = lowest time-to-first-token. Swap to claude-sonnet-4-6 if
# you want stronger tool-call reasoning at the cost of a little latency.
LLM_MODEL=claude-haiku-4-5-20251001

# Deepgram streaming STT model.
STT_MODEL=nova-3

# Cartesia Sonic TTS model + voice id (this is a stock Cartesia English voice).
TTS_MODEL=sonic-2
TTS_VOICE_ID=71a7ad14-091c-4e8e-a314-022ece01c121

# --- Turn-taking / latency knobs -------------------------------------------
# Seconds of silence before the agent gently checks "are you still there?".
IDLE_TIMEOUT_SECONDS=6.0

# Allow the caller to barge in (interrupt the agent mid-sentence).
ALLOW_INTERRUPTIONS=true

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=7860

# Path to the local SQLite store (created/seeded by scripts/seed_db.py).
DATABASE_PATH=data/voiceai.db

# Clinic timezone used when resolving "tomorrow", slot times, etc.
CLINIC_TIMEZONE=America/New_York
